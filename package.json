{
  "name": "ai-baram-detector",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "postinstall": "patch-package --error-on-fail",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test-admission:issue": "tsx --env-file=.env.local scripts/issue-analysis-test-admission.ts",
    "test-entitlement:issue": "tsx --env-file=.env.local scripts/issue-analysis-test-entitlement.ts",
    "canary:instagram": "tsx --env-file=.env.local scripts/canary-instagram-provider.ts",
    "canary:apify-profile-repair": "tsx --env-file=.env.local scripts/canary-apify-profile-repair.ts",
    "canary:instagram-profile-provider": "tsx --env-file=.env.local scripts/canary-instagram-profile-provider.ts",
    "canary:instagram-profile-provider:resolve": "tsx --env-file=.env.local scripts/resolve-profile-provider-canary-ambiguous-start.ts",
    "canary:instagram-profile-provider:finalize": "tsx --env-file=.env.local scripts/finalize-profile-provider-canary.ts"
  },
  "dependencies": {
    "@amplitude/unified": "1.1.25",
    "@axiomhq/js": "1.8.0",
    "@axiomhq/logging": "0.3.0",
    "@axiomhq/nextjs": "0.3.0",
    "@google-cloud/tasks": "6.2.3",
    "@google/genai": "^2.7.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.0",
    "@vercel/oidc": "3.8.0",
    "apify-client": "^2.21.0",
    "framer-motion": "^12.29.2",
    "google-auth-library": "10.9.0",
    "google-gax": "5.0.7",
    "js-yaml": "4.3.0",
    "libphonenumber-js": "^1.13.9",
    "next": "16.2.6",
    "patch-package": "8.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.8.0",
    "server-only": "0.0.1",
    "sharp": "0.35.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "8.22.0",
    "supabase": "^2.72.8",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "postcss": "8.5.15",
    "sharp": "$sharp"
  }
}
