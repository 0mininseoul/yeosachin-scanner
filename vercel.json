{
    "$schema": "https://openapi.vercel.sh/vercel.schema.json",
    "framework": "nextjs",
    "regions": [
        "icn1"
    ],
    "functions": {
        "app/api/analysis/run/route.ts": {
            "maxDuration": 300
        },
        "app/api/analysis/step/route.ts": {
            "maxDuration": 300
        },
        "app/api/analysis/v2/worker/route.ts": {
            "maxDuration": 300
        },
        "app/api/analysis/v2/recover/route.ts": {
            "maxDuration": 300
        },
        "app/api/analysis/preflight/retention/route.ts": {
            "maxDuration": 60
        }
    },
    "git": {
        "deploymentEnabled": {
            "main": true
        }
    }
}
