# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Groble earlybird presale (server-only; use existing dashboard values)
GROBLE_BASIC_PRODUCT_ID=
GROBLE_STANDARD_PRODUCT_ID=
GROBLE_BASIC_PAYMENT_ADDRESS=
GROBLE_STANDARD_PAYMENT_ADDRESS=
GROBLE_WEBHOOK_SECRET=
# Optional during an official Groble webhook-secret rotation window.
GROBLE_WEBHOOK_PREVIOUS_SECRET=

# OAuth (카카오)
KAKAO_CLIENT_ID=xxx
KAKAO_CLIENT_SECRET=xxx

# OAuth (구글)
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# Instagram provider credentials
APIFY_API_TOKEN=xxx
# Named primary is preferred; APIFY_API_TOKEN remains a backwards-compatible alias.
APIFY_PRIMARY_API_TOKEN=
# Legacy V1 explicit credential rotation/canary slot only.
APIFY_SECONDARY_API_TOKEN=
APIFY_API_TOKEN_SLOT=primary
# V2 normally chooses exactly one named slot per deployment/test. There is no automatic rotation,
# failover, or quota pooling; a durable run always resumes with its recorded slot. The separately
# signed, exact-target exception below is for one explicitly authorized E2E only.
APIFY_TERTIARY_API_TOKEN=
APIFY_QUATERNARY_API_TOKEN=
APIFY_QUINARY_API_TOKEN=
# Required explicit V2 slot. Launch E2E uses quinary; there is no implicit primary fallback.
ANALYSIS_V2_APIFY_API_TOKEN_SLOT=quinary
# Optional: manual FlashAPI diagnostic only; not used by the production default route.
FLASHAPI_RAPIDAPI_KEY=xxx
FLASHAPI_RAPIDAPI_HOST=flashapi1.p.rapidapi.com

# Deprecated Stable adapter: explicit operator selection only.
STABLE_RAPIDAPI_KEY=
STABLE_RAPIDAPI_HOST=
STABLE_RAPIDAPI_ESTIMATED_COST_PER_REQUEST_USD=
STABLE_RAPIDAPI_TIMEOUT_MS=30000

# Vertex AI Gemini
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true
# 기본 OFF: 프로필 1장 + 게시물 10장/1024px/gemini-3-flash-preview. true: 3장/384px/Flash-Lite/LOW media.
VERTEX_AI_COST_OPTIMIZED=false
# 계정 병렬 분석 수 (기본 5, 허용 1~10). 충분한 쿼터/메모리를 확인한 뒤 상향합니다.
VERTEX_AI_ANALYSIS_CONCURRENCY=5
# AI 결과와 함께 저장된 프로필 snapshot으로 재수집을 생략할 시간 (기본 12, 허용 6~24시간).
AI_PROFILE_SNAPSHOT_TTL_HOURS=12
# 선택적 명시 override. 비워두면 위 모드에 맞는 기본 모델을 사용합니다.
VERTEX_AI_MODEL=
# 로컬 개발에서는 GOOGLE_APPLICATION_CREDENTIALS에 서비스 계정 JSON 경로를 넣습니다.
# 운영 런타임은 연결된 서비스 계정 자격증명을 우선하고, 파일을 쓸 수 없는 호환 환경에서만 base64 값을 사용합니다.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# Resend (이메일)
RESEND_API_KEY=xxx
RESEND_FROM_EMAIL=noreply@baram-detector.com

# Amplitude
NEXT_PUBLIC_AMPLITUDE_API_KEY=xxx

# Axiom operational logs (server-only runtime ingest token)
AXIOM_TOKEN=
AXIOM_DATASET=yeosachin-logs
AXIOM_ORG_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_API_KEY=replace-with-a-long-random-secret
# Required dedicated HMAC key for short-lived stored-image proxy URLs.
# Generate at least 32 random characters; never reuse a database or provider key.
IMAGE_PROXY_SIGNING_SECRET=replace-with-at-least-32-random-characters
# Dedicated preflight target-identity HMAC key. Generate once with `openssl rand -base64 32`;
# keep it stable across retries/deploys and never reuse an auth, image, or provider secret.
ANALYSIS_V2_PREFLIGHT_IDENTITY_HMAC_SECRET=replace-with-base64-encoded-32-random-bytes
# Production deploys pin this exact Secret Manager numeric version immutably after first rollout.
# The current deploy path rejects in-place rotation even after a manual drain; use a new service or
# a future DB-backed, audited migration path rather than changing this worker's pinned version.
# Migration-only escape hatch. Keep false in production and local user flows.
ENABLE_LEGACY_ANALYSIS_RUN=false

# V2 launch gate. Keep production until a deliberately issued signed E2E entitlement is needed.
PREFLIGHT_ACCESS_MODE=production
ANALYSIS_TEST_ENTITLEMENTS_ENABLED=false
# Vercel intake only. Turning this off must not stop already queued work.
ANALYSIS_V2_ADMISSION_ENABLED=false
# Cloud Run drain and Scheduler recovery are independent operational gates.
ANALYSIS_V2_WORKER_ENABLED=false
ANALYSIS_V2_RECOVERY_ENABLED=false
# Dedicated HMAC key for short-lived admin-issued E2E entitlements. Never reuse a provider,
# database, auth, image-proxy, or Cloud Tasks secret. Use canonical base64url for exactly 32
# random bytes, for example: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
ANALYSIS_TEST_ENTITLEMENT_SECRET=replace-with-a-canonical-base64url-32-byte-secret

# Temporary, explicitly authorized exact-target E2E only. Keep false everywhere else. Enabling
# this does not change production admission or the default ANALYSIS_V2_APIFY_API_TOKEN_SLOT path.
# The operation map is persisted atomically with the signed request before its first dispatch.
ANALYSIS_V2_AUTHORIZED_TEST_SHARDING_ENABLED=false
ANALYSIS_V2_AUTHORIZED_TEST_SHARD_TARGET=
ANALYSIS_V2_AUTHORIZED_TEST_OWNER_USER_ID=
ANALYSIS_V2_AUTHORIZED_TEST_RELATIONSHIP_FOLLOWERS_SLOT=
ANALYSIS_V2_AUTHORIZED_TEST_RELATIONSHIP_FOLLOWING_SLOT=
ANALYSIS_V2_AUTHORIZED_TEST_PROFILE_FALLBACK_SLOT=
ANALYSIS_V2_AUTHORIZED_TEST_TARGET_LIKERS_SLOT=
ANALYSIS_V2_AUTHORIZED_TEST_TARGET_COMMENTS_SLOT=
ANALYSIS_V2_AUTHORIZED_TEST_CANDIDATE_LIKERS_SLOT=

# V2 free target preflight (Google Cloud Tasks -> authenticated preflight worker).
# Local after() execution is an explicit development-only fallback and is rejected in production.
PREFLIGHT_TASKS_ENABLED=false
PREFLIGHT_TASKS_PROJECT=your-project-id
PREFLIGHT_TASKS_LOCATION=asia-northeast3
PREFLIGHT_TASKS_QUEUE=analysis-preflight
PREFLIGHT_TASKS_TARGET_URL=https://your-production-domain.example/api/analysis/preflight/worker
PREFLIGHT_TASKS_OIDC_AUDIENCE=https://your-production-domain.example
PREFLIGHT_TASKS_SERVICE_ACCOUNT_EMAIL=analysis-v2-task@your-project-id.iam.gserviceaccount.com
PREFLIGHT_TASKS_ENQUEUER_SERVICE_ACCOUNT_EMAIL=analysis-v2-enqueuer@your-project-id.iam.gserviceaccount.com
# Use vercel-wif only in Vercel Production. Cloud Run and local gcloud ADC use adc.
PREFLIGHT_TASKS_CALLER_AUTH_MODE=adc
PREFLIGHT_TASKS_CLOUD_RUN_SERVICE=analysis-worker
PREFLIGHT_TASKS_CLOUD_RUN_REGION=asia-northeast3
PREFLIGHT_LOCAL_AFTER_ENABLED=false

# Durable V2 job ledger (separate from the legacy request-wide queue below).
# The worker task deadline is 300s and its fenced DB lease is 360s.
ANALYSIS_V2_TASKS_ENABLED=false
ANALYSIS_V2_TASKS_PROJECT=your-project-id
ANALYSIS_V2_TASKS_LOCATION=asia-northeast3
ANALYSIS_V2_TASKS_QUEUE=analysis-v2-pipeline
ANALYSIS_V2_TASKS_TARGET_URL=https://your-production-domain.example/api/analysis/v2/worker
ANALYSIS_V2_TASKS_OIDC_AUDIENCE=https://your-production-domain.example
ANALYSIS_V2_TASKS_SERVICE_ACCOUNT_EMAIL=analysis-v2-task@your-project-id.iam.gserviceaccount.com
# Use a dedicated V2/preflight enqueuer. Do not reuse the V1 enqueuer while it retains its
# legacy project-wide Cloud Tasks role.
ANALYSIS_V2_TASKS_ENQUEUER_SERVICE_ACCOUNT_EMAIL=analysis-v2-enqueuer@your-project-id.iam.gserviceaccount.com
# Use vercel-wif only in Vercel Production. The Cloud Run worker must use attached adc.
ANALYSIS_V2_TASKS_CALLER_AUTH_MODE=adc
# Shared non-secret provider resource used by both V2 and preflight WIF clients. The application
# derives the Vercel token audience (https://...) and Google STS audience (//...) separately.
GCP_VERCEL_WIF_PROVIDER_RESOURCE=projects/123456789012/locations/global/workloadIdentityPools/vercel-production/providers/ai-baram-detector
# Bootstrap-only immutable Vercel trust inputs for configure-analysis-v2-vercel-wif.sh.
VERCEL_OIDC_TEAM_SLUG=your-team-slug
VERCEL_OIDC_TEAM_ID=team_replace-with-your-team-id
VERCEL_OIDC_PROJECT_ID=prj_replace-with-your-project-id
ANALYSIS_V2_WORKER_RUNTIME_SERVICE_ACCOUNT_EMAIL=analysis-worker-runtime@your-project-id.iam.gserviceaccount.com
# Deprecated migration-only alias. Normally leave this unset; if both names are
# configured, they must resolve to the same service account.
# ANALYSIS_V2_TASKS_RECOVERY_SERVICE_ACCOUNT_EMAIL=analysis-worker-runtime@your-project-id.iam.gserviceaccount.com
# Dedicated Cloud Scheduler OIDC identity. It has no project role and cannot be reused by V1,
# Cloud Tasks, the worker runtime, the builder, or the Vercel WIF enqueuer.
ANALYSIS_V2_MAINTENANCE_SERVICE_ACCOUNT_EMAIL=analysis-v2-maintenance@your-project-id.iam.gserviceaccount.com
# Set on Cloud Run by deploy-analysis-v2-worker.sh from the service's canonical origin.
ANALYSIS_V2_MAINTENANCE_OIDC_AUDIENCE=https://your-cloud-run-worker-origin.example
ANALYSIS_V2_MAINTENANCE_LOCATION=asia-northeast3
ANALYSIS_V2_RECOVERY_SCHEDULER_JOB=analysis-v2-recovery
ANALYSIS_V2_RETENTION_SCHEDULER_JOB=analysis-v2-preflight-retention
# Exact resource-scoped actAs principal for runtime, build, and maintenance identities.
ANALYSIS_V2_DEPLOYER_IAM_MEMBER=user:operator@example.com
# Bootstrap-only legacy identities used to prove V2 never reuses a V1 trust boundary.
ANALYSIS_V1_TASKS_SERVICE_ACCOUNT_EMAIL=analysis-task@your-project-id.iam.gserviceaccount.com
ANALYSIS_V1_TASKS_ENQUEUER_SERVICE_ACCOUNT_EMAIL=analysis-v1-enqueuer@your-project-id.iam.gserviceaccount.com
ANALYSIS_V2_TASKS_CLOUD_RUN_SERVICE=analysis-worker
ANALYSIS_V2_TASKS_CLOUD_RUN_REGION=asia-northeast3
# V2-only bounded throughput. Generic/V1 queue defaults remain 2 dispatches/s and 2 concurrent.
ANALYSIS_V2_TASKS_MAX_DISPATCHES_PER_SECOND=8
ANALYSIS_V2_TASKS_MAX_CONCURRENT_DISPATCHES=8
# Launch-required private GCS bucket for short-lived normalized AI media. Keep it in the worker's
# region; enforce uniform bucket-level access + public access prevention; disable the default
# seven-day soft-delete policy and Object Versioning; configure an unconditional Age=1 Delete
# lifecycle; and grant the worker only object create/get/delete permissions.
ANALYSIS_V2_MEDIA_ARTIFACT_BUCKET=your-private-analysis-v2-artifact-bucket
ANALYSIS_V2_MEDIA_ARTIFACT_ROLE_ID=analysisV2MediaArtifactWorker
# Generate this once (for example: analysis-v2-lock-$(openssl rand -hex 16)), persist the
# resulting literal in protected deploy configuration, and never regenerate it per deploy.
ANALYSIS_V2_DEPLOY_LOCK_BUCKET=analysis-v2-lock-replace-with-openssl-rand-hex-16
# Apply infrastructure in this exact order: configure-analysis-v2-worker-identity.sh, then
# configure-analysis-v2-secrets.sh, configure-analysis-v2-media-bucket.sh, then
# deploy-analysis-v2-worker.sh. Secret versions are exact numeric pins returned by the secret
# provisioning script; never use latest.
ANALYSIS_V2_SUPABASE_SERVICE_ROLE_SECRET_VERSION=1
ANALYSIS_V2_APIFY_API_TOKEN_SECRET_VERSION=1
ANALYSIS_V2_IMAGE_PROXY_SIGNING_SECRET_VERSION=1
ANALYSIS_V2_PREFLIGHT_IDENTITY_HMAC_SECRET_VERSION=1
# The source dotenv and generated manifests must resolve outside the worker source tree. The
# provisioning script streams only its four allowlisted values directly to Secret Manager stdin.
# The generator copies no secrets: runtime YAML is non-secret and build YAML contains exactly the
# real public Supabase URL and anon key required by the clean Next.js source build.
ANALYSIS_V2_SECRET_SOURCE_ENV_FILE=/absolute/outside-repo/path/to/analysis-v2-source.env
ANALYSIS_V2_MANIFEST_SOURCE_ENV_FILE=/absolute/outside-repo/path/to/analysis-v2-source.env
ANALYSIS_V2_ENV_OUTPUT_DIR=/absolute/outside-repo/path/to/generated-manifests
# Cloud Run deploy-script controls. Keep generated manifests untracked and never commit them.
# Omit ANALYSIS_V2_WORKER_ENV_VARS_FILE on later deploys to preserve existing runtime variables.
# ANALYSIS_V2_WORKER_SOURCE_DIR=.
ANALYSIS_V2_WORKER_ENV_VARS_FILE=/absolute/outside-repo/path/to/generated-manifests/analysis-v2-runtime.yaml
# Required for every source deploy/dry-run; --check can only validate it when explicitly supplied.
ANALYSIS_V2_WORKER_BUILD_ENV_VARS_FILE=/absolute/outside-repo/path/to/generated-manifests/analysis-v2-build.yaml
ANALYSIS_V2_WORKER_BUILD_SERVICE_ACCOUNT=analysis-build@your-project-id.iam.gserviceaccount.com
ANALYSIS_V2_WORKER_CPU=2
ANALYSIS_V2_WORKER_MEMORY=2Gi
# Gemini concurrency is process-local, so launch with one worker instance and eight task slots.
ANALYSIS_V2_WORKER_CONCURRENCY=8
ANALYSIS_V2_WORKER_MAX_INSTANCES=1
ANALYSIS_V2_WORKER_TIMEOUT_SECONDS=300

# Durable background analysis (Google Cloud Tasks -> authenticated HTTPS step endpoint)
# Legacy V1 only. Keep disabled for local HTTP development.
ANALYSIS_TASKS_ENABLED=false
ANALYSIS_TASKS_PROJECT=your-project-id
ANALYSIS_TASKS_LOCATION=asia-northeast3
ANALYSIS_TASKS_QUEUE=analysis-pipeline
ANALYSIS_TASKS_TARGET_URL=https://your-production-domain.example/api/analysis/step
ANALYSIS_TASKS_OIDC_AUDIENCE=https://your-production-domain.example
ANALYSIS_TASKS_SERVICE_ACCOUNT_EMAIL=analysis-task@your-project-id.iam.gserviceaccount.com
ANALYSIS_TASKS_ENQUEUER_SERVICE_ACCOUNT_EMAIL=analysis-v1-enqueuer@your-project-id.iam.gserviceaccount.com

# ── Instagram provider routing (lib/services/instagram/README.md) ──
SCRAPER_PROFILE=selfhosted
SCRAPER_PROFILES_BATCH=selfhosted
SCRAPER_FOLLOWERS=apify
SCRAPER_FOLLOWING=apify
# Applies to selfhosted profile -> Apify only. Relationship operations have no automatic fallback.
SCRAPER_FALLBACK=true

# Manual FlashAPI diagnostic reliability and cost attribution
FLASHAPI_TIMEOUT_MS=10000
FLASHAPI_RETRIES=0
FLASHAPI_RETRY_BASE_DELAY_MS=500
FLASHAPI_MIN_INTERVAL_MS=1100
FLASHAPI_MAX_PAGES=200
FLASHAPI_USER_ID_CACHE_TTL_MS=600000
FLASHAPI_MIN_UNIQUE_RATIO=0.60
FLASHAPI_ESTIMATED_COST_PER_REQUEST_USD=0.00099
FLASHAPI_MAX_REQUESTS_PER_OPERATION=210
FLASHAPI_MAX_ESTIMATED_COST_USD_PER_OPERATION=0.21
FLASHAPI_RATE_LIMIT_REMAINING_RESERVE=5
FLASHAPI_QUOTA_STATE_TTL_MS=86400000

# Direct public-profile safety controls
# Supabase-backed aggregate start reservation shared by Vercel and Cloud Run. If omitted,
# this defaults on only when NODE_ENV=production. Set false locally to retain local-only behavior.
# Rollout order: first apply 20260716130001_add_selfhosted_profile_global_gate.sql through the
# normal ordered migration path (never --include-all), then deploy and enable Vercel and Cloud Run.
SELFHOSTED_PROFILE_GLOBAL_GATE_ENABLED=true
# Each reservation advances by interval + response guard (850ms by default); 237 starts take about 201s.
SELFHOSTED_PROFILE_GLOBAL_MIN_INTERVAL_MS=750
# Reject reservations whose RPC latency plus positive sleep overshoot exceeds this guard.
SELFHOSTED_PROFILE_GLOBAL_RESPONSE_GUARD_MS=100
# Hard deadline for the Supabase reservation RPC itself.
SELFHOSTED_PROFILE_GLOBAL_RPC_TIMEOUT_MS=750
# Admission fails fast; full fanout may wait longer, both before a reservation mutates global state.
SELFHOSTED_PROFILE_GLOBAL_ADMISSION_MAX_WAIT_MS=500
SELFHOSTED_PROFILE_GLOBAL_FULL_MAX_WAIT_MS=60000
# Process-local concurrency, interval, and circuit controls remain defense in depth.
SELFHOSTED_PROFILE_CONCURRENCY=4
SELFHOSTED_PROFILE_TIMEOUT_MS=8000
SELFHOSTED_PROFILE_RETRIES=1
SELFHOSTED_PROFILE_RETRY_BASE_DELAY_MS=750
SELFHOSTED_PROFILE_MIN_INTERVAL_MS=300
SELFHOSTED_PROFILE_CIRCUIT_COOLDOWN_MS=60000
SELFHOSTED_PROFILE_SCHEMA_FAILURE_THRESHOLD=2
SELFHOSTED_PROFILE_TRANSIENT_FAILURE_THRESHOLD=3
SELFHOSTED_PROFILE_MAX_RETRY_AFTER_MS=60000

# Apify relationship primary and profile fallback
APIFY_ACTOR_CONCURRENCY=2
APIFY_RELATIONSHIP_BUILD=0.0.71
APIFY_DATASET_READ_RETRIES=5
APIFY_DATASET_RETRY_BASE_DELAY_MS=500
APIFY_RELATIONSHIP_TIMEOUT_SECS=300
APIFY_RELATIONSHIP_MIN_UNIQUE_RATIO=0.95
# Conservative Free-plan attribution. After Starter activation and verification, use 0.00070.
APIFY_RELATIONSHIP_ESTIMATED_COST_PER_RESULT_USD=0.00085
APIFY_RELATIONSHIP_MAX_RESULTS_PER_OPERATION=1200
APIFY_RELATIONSHIP_MAX_ESTIMATED_COST_USD_PER_OPERATION=1.1
# Conservative Free-plan attribution. After Starter activation and verification, use 0.00230.
APIFY_PROFILE_TIMEOUT_SECS=300
APIFY_PROFILE_ESTIMATED_COST_PER_RESULT_USD=0.0026
APIFY_PROFILE_MAX_ESTIMATED_COST_USD_PER_OPERATION=1

# CoderX is explicit operator selection only.
CODERX_RELATIONSHIP_TIMEOUT_SECS=300
CODERX_RELATIONSHIP_MIN_UNIQUE_RATIO=0.95
CODERX_ESTIMATED_COST_PER_RESULT_USD=0.0013
CODERX_MAX_RESULTS_PER_OPERATION=1000
CODERX_MAX_ESTIMATED_COST_USD_PER_OPERATION=1.31

# Post-interaction adapters used by the interactions pipeline stage.
# DataDoping likers: 4 target posts x 150 or up to 10 candidate posts x 100.
# maxTotalChargeUsd is also set per run from the actual URL count and per-post limit.
APIFY_LIKERS_BUILD=0.0.9
APIFY_LIKERS_TIMEOUT_SECS=300
APIFY_LIKERS_MIN_UNIQUE_RATIO=0.95
APIFY_LIKERS_ESTIMATED_COST_PER_RESULT_USD=0.00155
APIFY_LIKERS_MAX_RESULTS_PER_POST=150
APIFY_LIKERS_MAX_URLS_PER_OPERATION=10
APIFY_LIKERS_MAX_TOTAL_RESULTS_PER_OPERATION=1500
APIFY_LIKERS_MAX_ESTIMATED_COST_USD_PER_OPERATION=2.325

# Official Apify comments: 6 target posts x 15 top-level comments, replies disabled.
APIFY_COMMENTS_BUILD=0.0.498
APIFY_COMMENTS_TIMEOUT_SECS=300
APIFY_COMMENTS_MIN_UNIQUE_RATIO=0.95
APIFY_COMMENTS_ESTIMATED_COST_PER_RESULT_USD=0.0026
APIFY_COMMENTS_MAX_RESULTS_PER_POST=15
APIFY_COMMENTS_MAX_URLS_PER_OPERATION=6
APIFY_COMMENTS_MAX_TOTAL_RESULTS_PER_OPERATION=90
APIFY_COMMENTS_MAX_ESTIMATED_COST_USD_PER_OPERATION=0.234

# Apply migrations 007-010 and all timestamped follow-ups before production analysis.
SCRAPER_TELEMETRY_PERSIST=false
